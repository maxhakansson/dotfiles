[alias]
    c = commit -am
    up = pull
    p = push
    s = status
    sclone = clone --depth=1
    co = checkout
    df = diff --color --color-words --abbrev
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --

    # Show the diff between the latest commit and the current state
    d = !"git diff-index --quiet HEAD -- || clear; git --no-pager diff --patch-with-stat"

    reup = rebase-update # depot_tools specific

    cleanup = "!git branch --merged | grep  -v '\\*\\|master\\|develop\\|rc\\|release' | xargs -n 1 git branch -d"


[core]
	excludesfile = ~/.gitignore_global
	attributesfile = ~/.gitattributes
	editor = nano

[pager]
    # Use delta for beautiful diffs (brew install git-delta)
    diff = delta
    show = delta
    log = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # Use n and N to move between diff sections
    light = false      # Set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
    side-by-side = false
    line-numbers = true
    line-numbers-left-format = ""
    line-numbers-right-format = "│ "

# so much color
[color]
    # ui = always
[color "diff"]
    meta = yellow bold
    commit = green bold
    frag = magenta bold
    old = red bold
    new = green bold
    whitespace = red reverse
[color "diff-highlight"]
    oldNormal = red bold
    oldHighlight = "red bold 52"
    newNormal = "green bold"
    newHighlight = "green bold 22"
[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green
[color "status"]
    added = yellow
    changed = green
    untracked = cyan

[diff]
    algorithm = histogram      # Better diff algorithm
    colorMoved = default       # Highlight moved code
    colorMovedWS = allow-indentation-change

[rerere]
    enabled = true            # Reuse recorded resolution of conflicts

# git mergetool
[merge]
    log = true
    tool = sublime-merge
    conflictstyle = zdiff3    # Even better than diff3
[url "git@github.com:"]
    insteadOf = "gh:"
    insteadOf = "git://github.com"
    pushInsteadOf = "github:"
    pushInsteadOf = "git://github.com/"
    pushInsteadOf = "https://github.com/"
[url "git@gist.github.com:"]
    insteadOf = "gst:"
    pushInsteadOf = "gist:"
    pushInsteadOf = "git://gist.github.com/"
    pushInsteadOf = "https://gist.github.com/"

# correct typos
[help]
    autocorrect = prompt      # Safer than auto-executing

# push easily. http://stackoverflow.com/a/23918418/89484
[push]
    default = current

[user]
	name = Max Hakansson
	email = mhakanss@conviva.com

[mergetool]
    keepBackup = false

# use separate file for username / github token / etc
[include]
  path = ~/.gitconfig.local

[filter "lfs"]
    clean = git-lfs clean %f
    smudge = git-lfs smudge %f
    required = true

[fetch]
    prune = true
    pruneTags = true          # Also prune deleted tags

#[commit]
#    template = ~/.stCommitMsg
[pull]
	rebase = true             # Cleaner history with rebase

[rebase]
	autoStash = true          # Auto-stash uncommitted changes
	updateRefs = true         # Update branch pointers

[init]
	defaultBranch = main
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = "smerge "
	trustExitCode = true
