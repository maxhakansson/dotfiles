# Use z for navidation
alias cd="z"

# mv, rm, cp
alias mv='mv -v'
# alias rm='rm -i -v'
# alias rm='trash' # npm install -g trash-cli
alias cp='cp -v'

# Modern ls replacement with eza (falls back to gls/ls if not available)
if command -v eza &> /dev/null; then
  alias ls='eza --group-directories-first'
  alias ll='eza -l --group-directories-first'
  alias la='eza -la --group-directories-first'
  alias lt='eza --tree --group-directories-first --level=2'
  alias lta='eza --tree --group-directories-first --level=2 -a'
fi

# Better cat with bat (preserving original cat for scripts)
if command -v bat &> /dev/null; then
  alias cat='bat --paging=never'
  alias catt='/bin/cat'  # Original cat when needed
fi

# Modern grep with ripgrep
if command -v rg &> /dev/null; then
  alias grep='rg'
  alias grepp='/usr/bin/grep'  # Original grep when needed
fi

alias hosts='sudo $EDITOR /etc/hosts'

# Shortcuts
alias d="cd ~/Documents/Dropbox"
alias dl="cd ~/Downloads"
alias dt="cd ~/Desktop"

###
# GIT STUFF
function clone() {
    git clone --depth=1 $1
    cd $(basename ${1%.*})
    npm install
}
alias push="git push"

# Undo a `git push` - DANGEROUS! Use with extreme caution
alias git-force-undo-push="git push -f origin HEAD^:master"

# git root
alias gr='[ ! -z `git rev-parse --show-cdup` ] && cd `git rev-parse --show-cdup || pwd`'
alias master="git checkout master"

# git log from head to master
alias changelog='git log --date=short --pretty=format:"%s" master..HEAD'

# View HTTP traffic
alias sniff="sudo ngrep -d 'en0' -t '^(GET|POST) ' 'tcp and port 80'"
alias httpdump="sudo tcpdump -i en0 -n -s 0 -w - | grep -a -o -E \"Host\: .*|GET \/.*\""

# Recursively delete `.DS_Store` files
alias cleanup_dsstore="find . -name '*.DS_Store' -type f -ls -delete"

alias diskspace_report="df -P -kHl"
alias free_diskspace_report="diskspace_report"

# Shortcuts
alias g="git"
alias ungz="gunzip -k"

# Modern git shortcuts
alias gst='git status'
alias gd='git diff'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias gco='git checkout'
alias gb='git branch'
alias glog='git log --oneline --graph --decorate'

# Lazygit (if installed)
if command -v lazygit &> /dev/null; then
  alias lg='lazygit'
fi

# File size
alias fs="stat -f \"%z bytes\""

# IP addresses
alias ip="dig +short myip.opendns.com @resolver1.opendns.com"
alias localip="ipconfig getifaddr en0"
alias ips="ifconfig -a | grep -o 'inet6\? \(addr:\)\?\s\?\(\(\([0-9]\+\.\)\{3\}[0-9]\+\)\|[a-fA-F0-9:]\+\)' | awk '{ sub(/inet6? (addr:)? ?/, \"\"); print }'"

# Show active network interfaces
alias ifactive="ifconfig | pcregrep -M -o '^[^\t:]+:([^\n]|\n\t)*status: active'"

# One of @janmoesen’s ProTip™s
for method in GET HEAD POST PUT DELETE TRACE OPTIONS; do
    alias "$method"="lwp-request -m '$method'"
done

# Empty the Trash on all mounted volumes and the main HDD. then clear the useless sleepimage
alias emptytrash=" \
    sudo rm -rfv /Volumes/*/.Trashes; \
    rm -rfv ~/.Trash/*; \
    sudo rm -v /private/var/vm/sleepimage; \
    rm -rv \"~/Library/Application Support/stremio/Cache\";  \
    rm -rv \"~/Library/Application Support/stremio/stremio-cache\" \
"

# Python
alias python=python3

# Run ffmpeg through Docker
alias ffmpeg='docker run -i --rm -u $UID:$GROUPS -v "$PWD:$PWD" -w "$PWD" mwader/static-ffmpeg:7.1.1'
alias avconv='docker run --rm -v=`pwd`:/files jedimonkey/avconv'

# Run SVTPlay-dl through docker
alias svtplay-dl='docker run -it --rm  -u $(id -u):$(id -g)  -v "$(pwd):/data" spaam/svtplay-dl'

# youtube download
alias yt-dl='docker run \
                  --rm -i \
                  -e PGID=$(id -g) \
                  -e PUID=$(id -u) \
                  -v "$(pwd)":/download:rw \
                  ghcr.io/jim60105/yt-dlp'

# Screenshare with Mac Studio
#alias studio='open vnc://max@"Max’s Mac Studio._rfb._tcp.local"'
alias studio='open vnc://max@192.168.0.10'
alias mini='open vnc://max@192.168.0.31'

